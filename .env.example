## Example environment for Project-RateEngine (backend)
## Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rateengine

# Django secret key (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Allowed hosts (comma-separated, REQUIRED in production)
# Example: example.com,www.example.com
ALLOWED_HOSTS=

# CORS allowed origins (comma-separated, REQUIRED in production)
# Example: https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# OPTIONAL / DEVELOPMENT
# =============================================================================

# Set to True for development mode (enables debug features and uses insecure defaults)
# NEVER set to True in production!
DJANGO_DEBUG=False

# Frontend URL for quote share links
FRONTEND_BASE_URL=http://localhost:3000

# Public quote link expiry (default: 7 days in seconds)
#PUBLIC_QUOTE_LINK_TTL_SECONDS=604800

# Set to True to enable self-registration (disabled by default)
# Even when enabled, users can only register as 'sales' role
#ALLOW_SELF_REGISTRATION=False

# =============================================================================
# AI SERVICES (if using AI intake feature)
# =============================================================================

# Google Gemini API key for AI rate intake
#GEMINI_API_KEY=

# Gemini model name for AI rate intake (defaults to gemini-2.5-flash-lite)
#GEMINI_MODEL_NAME=gemini-2.5-flash-lite
