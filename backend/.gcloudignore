db.sqlite3
*.sqlite3
*.db
.env
.env.*

# Logs and patch files
logs/
*.log
*.traceback
*.diff
out.txt
out2.txt

# Media & static files
media/
staticfiles/
test_staticfiles/
test_staticfiles_output/

# Knowledge Graph
graphify-out/
